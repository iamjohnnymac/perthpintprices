{
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "www.perthpintprices.com" }],
      "destination": "https://perthpintprices.com/:path",
      "statusCode": 301
    },
    {
      "source": "/suburb/:slug",
      "destination": "/:slug",
      "statusCode": 301
    },
    {
      "source": "/midland/the-7th-ave-bar-and-restaurant",
      "destination": "/midland/7th-ave-bar-and-restaurant",
      "statusCode": 301
    },
    {
      "source": "/northbridge/i-darts-nix-perth",
      "destination": "/northbridge/idartsnix",
      "statusCode": 301
    },
    {
      "source": "/scarborough/sk-l",
      "destination": "/scarborough/skol",
      "statusCode": 301
    },
    {
      "source": "/perth-cbd/helvetica-bar",
      "destination": "/perth/399-small-bar",
      "statusCode": 301
    },
    {
      "source": "/henley-brook/the-naked-fox-wine-bar",
      "destination": "/henley-brook/the-naked-fox-wine-bar-kitchen-and-caf",
      "statusCode": 301
    },
    {
      "source": "/guides",
      "destination": "/discover",
      "statusCode": 301
    },
    {
      "source": "/insights",
      "destination": "/discover",
      "statusCode": 301
    },
    {
      "source": "/world-cup",
      "destination": "/",
      "statusCode": 301
    }
  ],
  "crons": [
    {
      "path": "/api/cron/price-check",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/weekly-snapshot",
      "schedule": "0 22 * * 0"
    }
  ]
}
