    "test:redirects": "node scripts/redirect-seo.test.mjs",
    "test:headers": "node scripts/security-headers.test.mjs",
    "test:access": "node scripts/agent-access-preflight.test.mjs",
    "access:preflight": "node scripts/agent-access-preflight.mjs",
